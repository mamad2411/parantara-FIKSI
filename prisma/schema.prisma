generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Masjid {
  id          String   @id @default(cuid())
  nama        String
  alamat      String
  deskripsi   String?
  gambar      String?
  email       String?
  telepon     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  donasi      Donasi[]
  program     Program[]
  
  @@map("masjid")
}

model Program {
  id          String   @id @default(cuid())
  nama        String
  deskripsi   String
  target      Decimal  @db.Decimal(15, 2)
  terkumpul   Decimal  @default(0) @db.Decimal(15, 2)
  gambar      String?
  status      String   @default("aktif")
  masjidId    String
  masjid      Masjid   @relation(fields: [masjidId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  donasi      Donasi[]
  
  @@map("program")
}

model Donasi {
  id          String   @id @default(cuid())
  jumlah      Decimal  @db.Decimal(15, 2)
  nama        String
  email       String?
  telepon     String?
  pesan       String?
  anonim      Boolean  @default(false)
  status      String   @default("pending")
  metodeBayar String?
  masjidId    String
  masjid      Masjid   @relation(fields: [masjidId], references: [id], onDelete: Cascade)
  programId   String?
  program     Program? @relation(fields: [programId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@map("donasi")
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  nama        String
  password    String
  role        String   @default("user")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  masjidRegistrations MasjidRegistration[]
  
  @@map("users")
}

model MasjidRegistration {
  id                    String   @id @default(cuid())
  userId                String
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Step 1: Data Masjid
  mosqueName            String
  mosqueAddress         String
  province              String
  regency               String
  district              String
  village               String
  postalCode            String
  
  // Step 2: Data Legalitas
  aktaPendirian         String?
  skKemenkumham         String?
  npwpMasjid            String?
  
  // Step 3: Data Pengurus
  namaDepan             String
  namaBelakang          String
  jenisKelamin          String
  pekerjaan             String
  isPemilikBisnis       Boolean  @default(false)
  emailPerwakilan       String
  tanggalLahir          String
  nomorHandphone        String
  alamatTempat          String
  jenisID               String   @default("KTP")
  fotoKTP               String?
  nomorKTP              String
  suratKuasa            String?
  kontakPersonSama      Boolean  @default(true)
  
  // Step 4: Upload Dokumen
  skKepengurusan        String?
  suratRekomendasiRTRW  String?
  fotoTampakDepan       String?
  fotoInterior          String?
  dokumenStatusTanah    String?
  ktpKetua              String?
  npwpDokumen           String?
  
  // Step 5: Akun Admin
  adminEmail            String
  adminPassword         String
  
  // Status
  status                String   @default("pending") // pending, approved, rejected
  rejectionReason       String?
  fieldFeedback         Json?    // per-field review feedback
  approvedAt            DateTime?
  approvedBy            String?
  
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  @@map("masjid_registrations")
}
