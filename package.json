{
  "name": "danamasjid",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "lint": "eslint .",
    "start": "next start",
    "prepare": "husky",
    "optimize:images": "node scripts/optimize-images.js",
    "compress:videos": "node scripts/compress-videos.js",
    "compress:videos:balanced": "node scripts/compress-videos.js balanced",
    "compress:videos:small": "node scripts/compress-videos.js small",
    "analyze": "ANALYZE=true next build",
    "lighthouse": "lighthouse http://localhost:3000 --view",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:build": "docker-compose build",
    "docker:logs": "docker-compose logs -f",
    "docker:api": "docker-compose exec api sh",
    "docker:frontend": "docker-compose exec frontend sh",
    "docker:db": "docker-compose exec postgres psql -U danamasjid danamasjid",
    "docker:migrate": "docker-compose run --rm migration",
    "docker:clean": "docker-compose down -v --remove-orphans",
    "db:migrate": "cd api && npm run db:migrate",
    "db:generate": "cd api && npm run db:generate",
    "db:push": "cd api && npm run db:push",
    "db:studio": "cd api && npm run db:studio",
