# ============================================
# FRONTEND ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to git!

# ============================================
# API CONFIGURATION
# ============================================
# API Backend URL - Cloudflare Workers
# Development: http://localhost:3001
# Production: https://api.danamasjid.com or your Cloudflare Workers URL
NEXT_PUBLIC_API_URL=https://danamasjid-api.danamsjid-api.workers.dev

# ============================================
# GOOGLE RECAPTCHA V3
# ============================================
# Get your site key from: https://www.google.com/recaptcha/admin
# Use reCAPTCHA v3 for invisible protection
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your_recaptcha_site_key_here

# ============================================
# APP CONFIGURATION
# ============================================
# Your deployed app URL
# Development: http://localhost:3000
# Production: https://danamasjid.vercel.app
NEXT_PUBLIC_APP_URL=https://danamasjid.vercel.app

